<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Y2K Glam Social</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        /* Y2K Aesthetic Styling */
        body { background-color: #ff00ff; background-image: linear-gradient(45deg, #ff00ff 25%, #8000ff 75%); font-family: 'Comic Sans MS', cursive; color: white; text-align: center; padding: 20px; }
        .container { background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(10px); border: 3px solid #00ffff; border-radius: 20px; padding: 20px; max-width: 400px; margin: auto; box-shadow: 10px 10px 0px #000; }
        input { width: 80%; padding: 10px; margin: 10px; border: 2px solid #ff00ff; border-radius: 10px; }
        button { background: #00ffff; color: black; border: none; padding: 10px 20px; font-weight: bold; cursor: pointer; border-radius: 10px; box-shadow: 4px 4px 0px #000; }
        .hidden { display: none; }
        .search-box { margin-top: 20px; border-top: 2px dashed #00ffff; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>✨ Y2K Glam ✨</h1>
        
        <div id="auth-ui">
            <input type="email" id="email" placeholder="Email...">
            <input type="password" id="password" placeholder="Password...">
            <br>
            <button onclick="login()">Login</button>
            <button onclick="signUp()">Sign Up</button>
        </div>

        <div id="app-ui" class="hidden">
            <h2 id="welcome"></h2>
            <input type="text" id="username" placeholder="Your Display Name">
            <button onclick="saveName()">Save Name</button>
            
            <div class="search-box">
                <p>🔍 Search Friends</p>
                <input type="text" id="search" placeholder="Username...">
                <button onclick="alert('Searching...')">Search</button>
            </div>
            <br>
            <button style="background:#ff0000; color:white;" onclick="logout()">Logout</button>
        </div>
    </div>

    <script>
        const SB_URL = 'https://suizhwtixjifjharpagw.supabase.co';
        const SB_KEY = 'Sb_publishable_d-x18GJxfi-fuIXZ7hwxRg_vZixeSKK'; //
        const supabaseClient = supabase.createClient(SB_URL, SB_KEY);

        async function checkUser() {
            const { data: { user } } = await supabaseClient.auth.getUser();
            if (user) {
                document.getElementById('auth-ui').classList.add('hidden');
                document.getElementById('app-ui').classList.remove('hidden');
                document.getElementById('welcome').innerText = "Hi, " + user.email;
            }
        }

        async function signUp() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const { error } = await supabaseClient.auth.signUp({ email, password });
            if (error) alert(error.message); else alert("Check your email or just try logging in!");
        }

        async function login() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const { error } = await supabaseClient.auth.signInWithPassword({ email, password });
            if (error) alert(error.message);
            checkUser();
        }

        async function saveName() {
            const name = document.getElementById('username').value;
            const { data: { user } } = await supabaseClient.auth.getUser();
            const { error } = await supabaseClient.from('profiles').upsert({ id: user.id, username: name });
            if (error) alert("Error saving name. Make sure the table exists!"); else alert("Name Saved! ✨");
        }

        async function logout() { await supabaseClient.auth.signOut(); location.reload(); }
        checkUser();
    </script>
</body>
</html>
